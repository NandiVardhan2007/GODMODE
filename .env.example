# ============================================================
# G0DM0D3 — Environment Variables Reference
# Copy this to .env for local dev. Set in Render dashboard for production.
# NEVER commit .env with real keys to git.
# ============================================================

# ── REQUIRED ─────────────────────────────────────────────────
# Your OpenRouter API key — powers ALL model calls
# Get one at: https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxx

# Bearer token that callers must send in Authorization header
# Set this to any strong random string (e.g. openssl rand -hex 32)
# Your projects send:  Authorization: Bearer <this value>
GODMODE_API_KEY=your-secret-bearer-token-here

# ── TIER ACCESS ───────────────────────────────────────────────
# Maps keys to tiers: enterprise / pro / free
# Format: "enterprise:KEY1,pro:KEY2,pro:KEY3"
# Set GODMODE_API_KEY as enterprise so you get full ULTRAPLINIAN access
# Example:
GODMODE_TIER_KEYS=enterprise:your-secret-bearer-token-here

# ── CORS ─────────────────────────────────────────────────────
# Who can call this API from a browser.
# Use * to allow all origins (fine for a personal API)
# Or set to your exact frontend URL:  https://yourapp.onrender.com
CORS_ORIGIN=*

# ── RATE LIMITS ───────────────────────────────────────────────
# Max lifetime requests for "free" tier keys (0 = unlimited)
# Since you control access via GODMODE_API_KEY, set to 0
RATE_LIMIT_TOTAL=0

# ── OPTIONAL: HUGGINGFACE PUBLISHING ─────────────────────────
# Only needed if you want to publish chat data to a HF dataset.
# Leave blank to disable (safe default).
HF_TOKEN=
HF_DATASET_REPO=

# ── RUNTIME (Render sets this automatically — do not touch) ───
# PORT=10000
# NODE_ENV=production
